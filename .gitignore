.cargo
target
**/*.rs.bk
.idea
.claude
CLAUDE.md

# MkDocs build output
site/

# Build script output (scripts/build-{linux,windows}.sh)
dist/

# Benchmark artifacts (generated by CI workflows or local cargo bench runs)
bench-entry.json
bench-history.json
bench_report.md
bench_results.txt
bench_comparison.txt

# Python bytecode (only generated if you run python locally — CI never reads these)
__pycache__/
*.pyc

# Release workflow temp file (written by .github/workflows/release.yml)
release_body.md

# Release tarball produced locally (workflow uploads the same name to GitHub)
rust-samp-*-src.tar.gz

# Editor / OS junk
*.swp
*.swo
.DS_Store
Thumbs.db
